__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Caches
.ruff_cache/
.pyright_cache/

# Generated by scripts/check_phone_stream.py
stream_sample.png

# Local secrets (HF token etc.) - never commit
.env.local

