# IP Webcam stream settings for the phone camera.
# Committed on purpose for the hackathon (LAN-only, throwaway password).
# Edit PHONE_CAM_HOST to your phone's IP (shown in the IP Webcam app).

PHONE_CAM_HOST=192.168.179.146
PHONE_CAM_PORT=8080
PHONE_CAM_PATH=/video

# Login/password set in IP Webcam -> Connection -> Login/password
PHONE_CAM_USER=admin
PHONE_CAM_PASS=123123

# Must match the resolution/FPS the IP Webcam app actually emits. The robot
# inference config (run_robot_client.py) requires width/height/fps and, unlike
# the dashboard, cannot auto-detect them. Default 640x480@30 per the setup below.
PHONE_CAM_WIDTH=640
PHONE_CAM_HEIGHT=480
PHONE_CAM_FPS=30

# Alternatively, set a full URL to override the host/port/path above:
# PHONE_CAM_URL=http://192.168.1.42:8080/video

# --- USB streaming (adb port-forward) -------------------------------------
# Set true to tunnel the IP Webcam stream over the USB cable instead of WiFi.
# Requires `brew install android-platform-tools`, USB debugging on, `adb devices`
# showing the tablet, and IP Webcam running. Host is forced to localhost and the
# port is forwarded with `adb forward`; PHONE_CAM_HOST is ignored.
PHONE_CAM_USB=true
# PHONE_CAM_ADB=adb
# PHONE_CAM_ADB_SERIAL=        # only if several devices are attached
# PHONE_CAM_ADB_LOCAL_PORT=8080
# PHONE_CAM_ADB_REMOTE_PORT=8080

# --- SO-101 arms (arm_dashboard.py) ---------------------------------------
# Both arms plug into this computer over USB. Find the ports with:
#   uv run lerobot-find-port
FOLLOWER_PORT=/dev/tty.usbmodem5B415331931
LEADER_PORT=/dev/tty.usbmodem5B7B0166091
ROBOT_ID=so101_follower
LEADER_ID=so101_leader
# Workspace camera (icspring UVC webcam, overhead view). OpenCV device index from
# `lerobot-find-cameras` / AVFoundation: index 0 = icspring, index 1 = built-in
# FaceTime webcam. Maps to the policy's camera2 slot. Leave blank to disable.
ARM_CAM_INDEX=0
# Camera names are the policy-facing image-feature slots (observation.images.<name>) and
# MUST match the loaded policy's expected keys, not arbitrary labels. lerobot/smolvla_base
# expects camera1/camera2/camera3 (phone -> camera1 below).
ARM_CAM_NAME=camera2
ARM_CAM_WIDTH=640
ARM_CAM_HEIGHT=480
ARM_CAM_FPS=30
# Third camera = Luxonis OAK-D Lite (depthai/XLink, NOT a UVC webcam, so it has no
# OpenCV index). CAM3_SOURCE=oak makes the dashboard read it via depthai (oak_camera.py).
# CAM3_INDEX stays blank: lerobot's opencv camera backend can't open the OAK, so the
# robot/inference path skips camera3 for now (OAK-in-inference is a follow-up).
CAM3_SOURCE=oak
CAM3_INDEX=
CAM3_NAME=camera3
CAM3_WIDTH=640
CAM3_HEIGHT=480
CAM3_FPS=30
# Video codec for recorded datasets. Streaming encoding runs during capture so recording is
# continuous (no per-episode encode wait). "auto" = hardware encoder (h264_videotoolbox on
# this Mac) which keeps up with 3 cameras in real time. Use "libsvtav1" for AV1 (software,
# matches the older s2/s4 datasets, but may drop frames if it can't keep up).
RECORD_VCODEC=auto
# Calibration lives in the repo at calibration/<id>.json (committed). Override
# only if you have different physical arms. Blank = <repo>/calibration.
CALIBRATION_DIR=
TELEOP_FPS=60
DASHBOARD_PORT=8041

# Web dashboard login (HTTP Basic Auth). Leave DASHBOARD_PASS empty to disable.
DASHBOARD_USER=admin
DASHBOARD_PASS=123123

# --- VLA policy inference --------------------------------------------------
# Shared policy settings. HF token for gated models (pi0 etc.) goes in
# .env.local, NOT here.
INFERENCE_FPS=30
POLICY_PATH=nsuprun/merged-so101-49904152
POLICY_TASK=Pick up the cube
POLICY_TYPE=act

# Local single-machine inference (arm_dashboard.py): device the policy runs on
# THIS Mac. Blank = auto (mps).
POLICY_DEVICE=

# Remote inference (run_policy_server.py on the GPU box + run_robot_client.py
# here). POLICY_SERVER_ADDRESS is the GPU box reachable from this Mac.
POLICY_SERVER_ADDRESS=100.84.11.4:8080
POLICY_SERVER_HOST=0.0.0.0
POLICY_SERVER_PORT=8080
SERVER_POLICY_DEVICE=cuda
CLIENT_DEVICE=cpu
ACTIONS_PER_CHUNK=50
CHUNK_SIZE_THRESHOLD=0.5
AGGREGATE_FN=weighted_average
# Server re-runs inference only when an observation differs from the last by more than this
# joint-space L2 tolerance (degrees). LeRobot's default is 1.0; lower = more sensitive (the
# stock filter is joint-only and skips too aggressively). Used by run_policy_server.py.
OBS_SIMILARITY_ATOL=0.1
# Phone maps to the policy's primary image slot (smolvla_base: camera1/camera2/camera3).
ROBOT_CAMERA_NAME=camera1

# SSH tunnel to the GPU box (run_tunnel.py) — NOT needed with Tailscale, and the
# box currently has no sshd listening. Password lives in .env.local if enabled.
GPU_SSH_HOST=nick@100.84.11.4
GPU_SSH_PORT=22
TUNNEL_LOCAL_PORT=8080
