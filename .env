# IP Webcam stream settings for the phone camera.
# Committed on purpose for the hackathon (LAN-only, throwaway password).
# Edit PHONE_CAM_HOST to your phone's IP (shown in the IP Webcam app).

PHONE_CAM_HOST=192.168.179.146
PHONE_CAM_PORT=8080
PHONE_CAM_PATH=/video

# Login/password set in IP Webcam -> Connection -> Login/password
PHONE_CAM_USER=admin
PHONE_CAM_PASS=123123

# Must match the resolution/FPS the IP Webcam app actually emits. The robot
# inference config (run_robot_client.py) requires width/height/fps and, unlike
# the dashboard, cannot auto-detect them. Default 640x480@30 per the setup below.
PHONE_CAM_WIDTH=640
PHONE_CAM_HEIGHT=480
PHONE_CAM_FPS=30

# Alternatively, set a full URL to override the host/port/path above:
# PHONE_CAM_URL=http://192.168.1.42:8080/video

# --- SO-101 arms (arm_dashboard.py) ---------------------------------------
# Both arms plug into this computer over USB. Find the ports with:
#   uv run lerobot-find-port
FOLLOWER_PORT=/dev/tty.usbmodem5B415331931
LEADER_PORT=/dev/tty.usbmodem5B7B0166091
ROBOT_ID=so101_follower
LEADER_ID=so101_leader
# USB wrist camera on the arm (OpenCV device index from `lerobot-find-cameras`).
# Leave blank if there is no wrist camera.
ARM_CAM_INDEX=0
ARM_CAM_NAME=wrist
ARM_CAM_WIDTH=640
ARM_CAM_HEIGHT=480
ARM_CAM_FPS=30
# Calibration lives in the repo at calibration/<id>.json (committed). Override
# only if you have different physical arms. Blank = <repo>/calibration.
CALIBRATION_DIR=
TELEOP_FPS=60
DASHBOARD_PORT=8041

# Web dashboard login (HTTP Basic Auth). Leave DASHBOARD_PASS empty to disable.
DASHBOARD_USER=admin
DASHBOARD_PASS=123123

# --- VLA policy inference --------------------------------------------------
# Shared policy settings. HF token for gated models (pi0 etc.) goes in
# .env.local, NOT here.
INFERENCE_FPS=30
POLICY_PATH=lerobot/smolvla_base
POLICY_TASK=Pick up the cube
POLICY_TYPE=smolvla

# Local single-machine inference (arm_dashboard.py): device the policy runs on
# THIS Mac. Blank = auto (mps).
POLICY_DEVICE=

# Remote inference (run_policy_server.py on the GPU box + run_robot_client.py
# here). POLICY_SERVER_ADDRESS is the GPU box reachable from this Mac.
POLICY_SERVER_ADDRESS=100.84.11.4:8080
POLICY_SERVER_HOST=0.0.0.0
POLICY_SERVER_PORT=8080
SERVER_POLICY_DEVICE=cuda
CLIENT_DEVICE=cpu
ACTIONS_PER_CHUNK=50
CHUNK_SIZE_THRESHOLD=0.5
AGGREGATE_FN=weighted_average
ROBOT_CAMERA_NAME=phone

# SSH tunnel to the GPU box (run_tunnel.py) — NOT needed with Tailscale, and the
# box currently has no sshd listening. Password lives in .env.local if enabled.
GPU_SSH_HOST=nick@100.84.11.4
GPU_SSH_PORT=22
TUNNEL_LOCAL_PORT=8080
